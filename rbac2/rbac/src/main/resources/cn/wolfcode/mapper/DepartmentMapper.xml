<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="cn.wolfcode.mapper.DepartmentMapper">


    <insert id="addDepartment">
insert into department(name,sn) values(#{name},#{sn})
    </insert>
    <update id="updateDepartment">
        update department set
        name =#{name},
        sn = #{sn}
        where id= #{id}
    </update>
    <delete id="deleteDepartment">
delete from department where id = #{id}
    </delete>



    <select id="getDepartment" resultType="cn.wolfcode.domain.Department">
        select id,name,sn from department where id=#{id}
    </select>
    <select id="selectAllDepartment" resultType="cn.wolfcode.domain.Department">
        select id,name,sn from Department
    </select>

    <select id="selectDepartmentByQuery" resultType="cn.wolfcode.domain.Department">
        select id,name,sn from Department
        <where>
            <if test="name != null and name != ''">
                and name like concat('%', #{name}, '%')
            </if>
            <if test="sn != null and sn != ''">
                and sn like concat('%', #{sn}, '%')
            </if>
        </where>
    </select>


</mapper>